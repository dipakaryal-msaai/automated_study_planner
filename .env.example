# Database Configuration for Automated Study Planner

# For local development with SQLite (default)
# DATABASE_URL=sqlite:///data/study_planner.db

# For PostgreSQL (uncomment and configure for production/Heroku)
# DATABASE_URL=postgresql://username:password@localhost:5432/study_planner

# Note: Heroku automatically sets DATABASE_URL for PostgreSQL
# You don't need to set it manually when deploying to Heroku

# Flask Secret Key (change in production)
# SECRET_KEY=your-secret-key-here
